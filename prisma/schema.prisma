generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id            Int     @id @default(autoincrement())
  name          String
  title         String
  photoUrl      String?
  bio           String
  email         String?
  phone         String?
  address       String?
  scopusUrl     String?
  scopusHIndex  String?
  scholarUrl    String?
  scholarHIndex String?
}

model Education {
  id          Int     @id @default(autoincrement())
  level       String
  institution String
  faculty     String?
  major       String?
  period      String
  location    String?
  link        String?
  fileUrl     String?
  sortOrder   Int     @default(0)
}

model Experience {
  id          Int     @id @default(autoincrement())
  position    String
  institution String
  period      String
  current     Boolean @default(false)
  link        String?
  fileUrl     String?
  sortOrder   Int     @default(0)
}

model Teaching {
  id          Int     @id @default(autoincrement())
  title       String
  institution String
  year        String
  description String?
  link        String?
  fileUrl     String?
  sortOrder   Int     @default(0)
}

model Publication {
  id        Int     @id @default(autoincrement())
  category  String
  title     String
  authors   String?
  year      String
  venue     String?
  details   String?
  link      String?
  fileUrl   String?
  sortOrder Int     @default(0)
}

model Project {
  id          Int     @id @default(autoincrement())
  title       String
  year        String
  client      String?
  description String?
  link        String?
  imageUrl    String?
  sortOrder   Int     @default(0)
}

model Skill {
  id        Int     @id @default(autoincrement())
  category  String
  items     String
  link      String?
  fileUrl   String?
  sortOrder Int     @default(0)
}

model ResearchInterest {
  id        Int     @id @default(autoincrement())
  text      String
  link      String?
  fileUrl   String?
  sortOrder Int     @default(0)
}

model Certification {
  id        Int     @id @default(autoincrement())
  title     String
  year      String
  provider  String?
  link      String?
  fileUrl   String?
  sortOrder Int     @default(0)
}

model CustomLink {
  id        Int     @id @default(autoincrement())
  label     String
  url       String
  icon      String?
  fileUrl   String?
  sortOrder Int     @default(0)
}

model AdminUser {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
}

model PageMeta {
  slug        String  @id
  title       String?
  description String?
}
